              }
            }
          },
          "500": {
            "description": "Common response for all operations that can fail with an unexpected server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/agents/search": {
      "post": {
        "tags": ["WellKnown"],
        "operationId": "searchAgentsAdvanced",
        "summary": "Search agents with advanced filters",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent search results.",
