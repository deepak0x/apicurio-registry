          "detail": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "AgentCard": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "protocolVersion": {
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/AgentProvider"
          },
          "capabilities": {
            "$ref": "#/components/schemas/AgentCapabilities"
