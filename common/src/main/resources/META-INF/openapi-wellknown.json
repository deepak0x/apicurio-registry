{
  "openapi": "3.0.3",
  "info": {
    "title": "Apicurio Registry - Well-Known Endpoints",
    "version": "3.0.x",
    "description": "Well-known endpoints for agent card discovery, MCP tool discovery, and schema retrieval.",
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    }
  },
  "servers": [
    {
      "url": ""
    }
  ],
  "paths": {
    "/.well-known/agent.json": {
      "get": {
        "tags": ["WellKnown"],
        "operationId": "getAgentCard",
        "summary": "Get the agent card for this registry instance",
        "responses": {
          "200": {
            "description": "The agent card.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentCard"
                }
              }
            }
          },
          "500": {
            "description": "Common response for all operations that can fail with an unexpected server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/a2a": {
      "get": {
        "tags": ["WellKnown"],
        "operationId": "getAgentCardV1",
        "summary": "Get the agent card (A2A v1 path)",
        "responses": {
          "200": {
            "description": "The agent card.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentCard"
                }
              }
            }
          },
          "500": {
            "description": "Common response for all operations that can fail with an unexpected server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
