      }
    },
    "/.well-known/agents/public": {
      "get": {
        "tags": ["WellKnown"],
        "operationId": "getPublicAgents",
        "summary": "Get public agents",
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of public agents.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentSearchResults"
                }
              }
            }
          },
          "500": {
            "description": "Common response for all operations that can fail with an unexpected server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/agents/entitled": {
      "get": {
        "tags": ["WellKnown"],
        "operationId": "getEntitledAgents",
        "summary": "Get entitled agents",
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
